# STATE.a2ml — Project state checkpoint

[metadata]
project = "jaffascript"
version = "0.1.0"
last-updated = "2026-06-18"
status = "active"  # active | paused | archived

[project-context]
name = "jaffascript"
purpose = "JavaScript / TypeScript face (brand surface) over AffineScript. Holds JS/TS-idiomatic examples, community docs, migration guides, and the `jaffa` shim CLI. All compiler internals live in affinescript and are shared, unchanged, by every face."
completion-percentage = 40

[position]
phase = "implementation"   # design | implementation | testing | maintenance | archived
maturity = "alpha"         # experimental | alpha | beta | production | lts

[route-to-mvp]
milestones = [
  { name = "RSR-standard repository layout at parity with rattlescript", completion = 100 },
  { name = "Genuine JS/TS-idiomatic README + hello example", completion = 100 },
  { name = "Machine-readable identity (6a2) populated", completion = 80 },
  { name = "JS/TS -> AffineScript migration guide (docs/)", completion = 0 },
  { name = "Idiomatic example corpus beyond hello", completion = 0 },
  { name = "Same-cube conformance wired to affinescript preview-js", completion = 0 },
]

[blockers-and-issues]
# Depends on lib/js_face.ml in affinescript (ADR-010). Known transformer gaps
# are tracked in affinescript/examples/faces/README.adoc under "Known transformer gaps".

[critical-next-actions]
actions = [
  "Author JS/TS -> AffineScript migration guide under docs/",
  "Grow the example corpus (modules, effects, resource handles) in jaffa syntax",
  "Wire same-cube verification: preview-js output diffed against canonical",
]

[maintenance-status]
last-run-utc = "never"
last-result = "unknown"  # unknown | pass | warn | fail
open-warnings = 0
open-failures = 0

[ecosystem]
part-of = ["AffineScript faces", "RSR Framework"]
depends-on = ["affinescript"]
