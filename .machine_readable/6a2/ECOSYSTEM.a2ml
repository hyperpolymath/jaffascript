#
# ECOSYSTEM.a2ml — Project ecosystem position
# Relationships, dependencies, integration points.

[metadata]
version = "0.1.0"
last-updated = "2026-06-18"

[project]
name = "jaffascript"
purpose = "JavaScript / TypeScript surface face over AffineScript. A brand surface that pre-selects the `jaffa` face; the compiler, type checker, borrow checker, and codegen live in affinescript."
role = "language-face"  # surface dialect / brand surface over the canonical AffineScript core

[position-in-ecosystem]
tier = "2"  # 1 | 2 | infrastructure

[related-projects]
# relationship types: sibling-standard, dependency, dependent, inspiration, potential-consumer
related = [
  { name = "affinescript",      relationship = "dependency",         note = "canonical core; hosts lib/js_face.ml and the whole shared compiler pipeline" },
  { name = "rattlescript",      relationship = "sibling-standard",   note = "Python face" },
  { name = "lucidscript",       relationship = "sibling-standard",   note = "PureScript / Haskell face" },
  { name = "cafescripto",       relationship = "sibling-standard",   note = "CoffeeScript face" },
  { name = "pseudoscript",      relationship = "sibling-standard",   note = "pseudocode face" },
  { name = "aggregate-library", relationship = "potential-consumer", note = "cross-face conformance overlap (extension layer)" },
]

[integration-points]
# External systems this project connects to
integrations = [
  { system = "affinescript", direction = "outbound", protocol = "cli", note = "bin/jaffa shims `affinescript --face jaffa`" },
]
